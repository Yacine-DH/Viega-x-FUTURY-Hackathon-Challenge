# Copy this file to .env and fill in your values

# --- Google Cloud ---
GCP_PROJECT_ID=futury-accel26fra-510
GCP_LOCATION=us-central1
FIRESTORE_DATABASE=(default)

# --- External APIs ---
NEWS_API_KEY=
TRADING_ECONOMICS_API_KEY=
FIRECRAWL_API_KEY=

# --- EPO OPS (https://developers.epo.org/ — free registration) ---
EPO_CLIENT_ID=
EPO_CLIENT_SECRET=

# --- SEC API (https://sec-api.io — optional, NIBCO uses free EDGAR RSS) ---
SEC_API_KEY=

# --- Scheduler ---
WEBHOOK_BASE_URL=http://localhost:8000

